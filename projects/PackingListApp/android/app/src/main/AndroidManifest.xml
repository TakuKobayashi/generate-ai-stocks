<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />

    <application
        android:name=".PackingListApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.PackingList"
        tools:targetApi="31">
        
        <!-- AdMob App ID -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />
        
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.PackingList">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ui.ItemListActivity"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PackingList" />
        
        <activity
            android:name=".ui.ChecklistActivity"
            android:parentActivityName=".ui.ItemListActivity"
            android:theme="@style/Theme.PackingList" />
        
        <activity
            android:name=".ui.EventListActivity"
            android:parentActivityName=".ui.MainActivity"
            android:theme="@style/Theme.PackingList" />
        
        <!-- Widget Provider -->
        <receiver
            android:name=".widget.PackingListWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.example.packinglist.ACTION_VIEW_ITEMS" />
                <action android:name="com.example.packinglist.ACTION_VIEW_CHECKLISTS" />
                <action android:name="com.example.packinglist.ACTION_BACK" />
                <action android:name="com.example.packinglist.ACTION_VIEW_CHECKLIST_DETAIL" />
                <action android:name="com.example.packinglist.ACTION_TOGGLE_CHECK" />
                <action android:name="com.example.packinglist.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/packing_list_widget_info" />
        </receiver>
        
        <!-- Widget Services -->
        <service
            android:name=".widget.PackingListWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
        
        <service
            android:name=".widget.ItemsWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
        
        <service
            android:name=".widget.ChecklistsWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
        
        <service
            android:name=".widget.ChecklistDetailWidgetService"
            android:permission="android.permission.BIND_REMOTEVIEWS"
            android:exported="false" />
    </application>

</manifest>
