{
  "name": "github-kv-chat",
  "main": "src/index.ts",
  "compatibility_date": "2024-12-01",
  "compatibility_flags": ["nodejs_compat"],

  "assets": {
    "directory": "../web/out",
    "binding": "ASSETS"
  },

  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "YOUR_KV_NAMESPACE_ID",
      "preview_id": "YOUR_KV_PREVIEW_ID"
    }
  ],

  "triggers": {
    "crons": ["0 0 * * *"]
  },

  "vars": {
    "GITHUB_REPO_OWNER": "owner",
    "GITHUB_REPO_NAME": "repo",
    "OPENAI_API_KEY": "dummy-replace-me"
  }
}
