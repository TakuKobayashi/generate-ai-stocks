<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <!-- タイトル -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎙️ Whisper 文字起こし"
        android:textAppearance="?attr/textAppearanceTitleLarge"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="16dp" />

    <!-- ステータスカード -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="?attr/colorOutlineVariant"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/text_state_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏸️"
                    android:textSize="24sp"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/text_status"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/status_idle"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurface" />

            </LinearLayout>

            <!-- 音量インジケーター -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/level_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:indicatorColor="?attr/colorPrimary"
                app:trackColor="?attr/colorSurfaceVariant"
                android:max="100"
                android:progress="0" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 最新文字起こし結果カード -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorPrimaryContainer"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="最新の文字起こし"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/text_latest_transcription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/latest_transcription_hint"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:minLines="2" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Start / Stop ボタン -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_start_stop"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/start"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        android:layout_marginBottom="20dp" />

    <!-- 履歴ヘッダー -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="履歴"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp" />

    <!-- 履歴が空の場合 -->
    <TextView
        android:id="@+id/text_empty_history"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/empty_history"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:paddingVertical="32dp"
        android:visibility="visible" />

    <!-- 履歴リスト -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"
        android:clipToPadding="false" />

</LinearLayout>
