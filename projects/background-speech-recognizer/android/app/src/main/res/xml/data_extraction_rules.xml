<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ のバックアップ設定
  録音ファイルはデバイスローカルに保持（バックアップ対象外）
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
    </device-transfer>
</data-extraction-rules>
