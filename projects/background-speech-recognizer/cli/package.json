{
  "name": "whisper-local-cli",
  "version": "2.0.0",
  "description": "ローカル完結リアルタイム音声文字起こしCLI（whisper.cpp + VAD）Windows/Linux/macOS対応",
  "main": "dist/bin/cli.js",
  "bin": {
    "whisper-cli": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/bin/cli.js start",
    "start:gc": "node --expose-gc dist/bin/cli.js start",
    "dev": "tsx src/bin/cli.ts start",
    "dev:gc": "node --expose-gc --import tsx src/bin/cli.ts start",
    "download-model": "tsx src/bin/cli.ts download-model",
    "doctor": "tsx src/bin/cli.ts doctor",
    "models": "tsx src/bin/cli.ts list-models",
    "cli": "tsx src/bin/cli.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "watch": "tsx watch src/bin/cli.ts start",
    "claude": "dotenv -- claude"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "mic": "^2.1.2",
    "node-vad": "^1.1.4",
    "wav": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/wav": "^1.0.4",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "win32",
    "linux",
    "darwin"
  ]
}
