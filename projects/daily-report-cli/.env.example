# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Asana OAuth
ASANA_CLIENT_ID=your_asana_client_id
ASANA_CLIENT_SECRET=your_asana_client_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Trello
TRELLO_API_KEY=your_trello_api_key

# AI要約API (オプション)
# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini  # または gpt-4o, gpt-3.5-turbo など

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-haiku-20240307  # または claude-3-5-sonnet-20241022 など

# Optional: 直接トークンを指定する場合(セキュリティ上非推奨)
# GITHUB_TOKEN=your_github_token
# ASANA_TOKEN=your_asana_token
# GOOGLE_TASKS_TOKEN=your_google_tasks_token
# TRELLO_TOKEN=your_trello_token
