# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.local-worker
# 自前GPUサーバー上で動かすAiderワーカー
# 起動後は Cloudflare Tunnel で外部公開する
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-slim

# ── システムパッケージ ──────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv \
    gnupg \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI ────────────────────────────────────────────────────────────
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      | tee /etc/apt/sources.list.d/github-cli.list > /dev/null \
    && apt-get update && apt-get install -y gh \
    && rm -rf /var/lib/apt/lists/*

# ── Cloudflare Tunnel (cloudflared) ──────────────────────────────────────
RUN curl -fsSL https://github.com/cloudflare/cloudflared/releases/latest/download/cloudflared-linux-amd64 \
      -o /usr/local/bin/cloudflared \
    && chmod +x /usr/local/bin/cloudflared

# ── pnpm + tsx ────────────────────────────────────────────────────────────
RUN npm install -g pnpm tsx

# ── Python仮想環境: Aider ─────────────────────────────────────────────────
ENV VENV_PATH=/opt/venv
RUN python3 -m venv $VENV_PATH
ENV PATH="$VENV_PATH/bin:$PATH"
RUN pip install --no-cache-dir aider-chat && pip cache purge

# ── アプリケーション ──────────────────────────────────────────────────────
WORKDIR /app

COPY local-worker/package.json local-worker/pnpm-lock.yaml* ./local-worker/
COPY cloudflare-workers/src/index.ts ./cloudflare-workers/src/

RUN cd local-worker && pnpm install --frozen-lockfile --prod

COPY local-worker/src/ ./local-worker/src/

RUN git config --global user.email "aider-agent@bot.local" \
    && git config --global user.name "Aider AI Agent"

EXPOSE 3000

# HTTPサーバーとして起動 (Ollamaは別コンテナまたはホストで起動済み前提)
CMD ["tsx", "local-worker/src/server.ts"]
