# ─────────────────────────────────────────────────────────────────────────────
# Dockerfile.webhook
# Cloud Run: GitHub Webhookレシーバー (軽量Node.jsイメージ)
# ─────────────────────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app
RUN npm install -g pnpm

COPY gcp-webhook/package.json gcp-webhook/pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile

COPY gcp-webhook/src ./src
COPY gcp-webhook/tsconfig.json ./
RUN pnpm exec tsc

# ─── Runtime ─────────────────────────────────────────────────────────────────
FROM node:20-alpine AS runtime

WORKDIR /app
RUN npm install -g pnpm

COPY --from=builder /app/package.json ./
COPY --from=builder /app/dist ./dist
COPY gcp-webhook/package.json ./
RUN pnpm install --frozen-lockfile --prod

ENV NODE_ENV=production
ENV PORT=8080

EXPOSE 8080
CMD ["node", "dist/index.js"]
