<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGetForUnity パッケージ定義
  ─────────────────────────────────────────────────────────────
  MessagePack-CSharp (2.5.187)
    ・高速バイナリシリアライザ (MessagePack)
    ・DataChannel ペイロードのエンコード/デコードに使用
    ・[MessagePackObject] アトリビュートで C# 型を定義

  Websocket.Client (5.1.2)
    ・PartyKit シグナリング用 WebSocket クライアント
    ・自動再接続・IObservable 対応

  System.Reactive (6.0.1)
    ・Websocket.Client の IObservable に必要

  Newtonsoft.Json (13.0.3)
    ・シグナリングメッセージ (JSON) のシリアライズに使用

  Unity.WebRTC (3.0.0)
    ・Unity 公式 WebRTC パッケージ (com.unity.webrtc)
    ・NuGet ではなく Package Manager から導入すること
    ・Window > Package Manager > + > Add package by name
    ・com.unity.webrtc
  ─────────────────────────────────────────────────────────────
-->
<packages>
  <package id="MessagePack"                  version="2.5.187" />
  <package id="MessagePack.Annotations"      version="2.5.187" />
  <package id="Websocket.Client"             version="5.1.2"   />
  <package id="System.Reactive"              version="6.0.1"   />
  <package id="Newtonsoft.Json"              version="13.0.3"  />
  <package id="Microsoft.Extensions.Logging.Abstractions" version="8.0.2" />
</packages>
