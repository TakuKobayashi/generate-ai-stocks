<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- Processed preview (light/shadow removal modes) -->
    <ImageView
        android:id="@+id/processedPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:scaleType="centerCrop" />

    <!-- Grid overlay -->
    <com.example.pixelcamera.GridOverlayView
        android:id="@+id/gridOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Level indicator -->
    <com.example.pixelcamera.LevelIndicatorView
        android:id="@+id/levelIndicator"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Focus ring (tap + motion AF) -->
    <com.example.pixelcamera.FocusRingView
        android:id="@+id/focusRing"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- MotionAF state indicator badge (right side, vertically centered) -->
    <com.example.pixelcamera.MotionAfIndicatorView
        android:id="@+id/motionAfIndicator"
        android:layout_width="70dp"
        android:layout_height="32dp"
        android:layout_margin="12dp"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zoom text overlay -->
    <TextView
        android:id="@+id/zoomText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.0×"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:background="#66000000"
        android:padding="4dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ===== TOP BAR ===== -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#CC000000"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton android:id="@+id/btnFlash"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_flash_auto"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Flash" />

        <ImageButton android:id="@+id/btnHdr"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_hdr_auto"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="HDR" />

        <ImageButton android:id="@+id/btnTimer"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_timer_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Timer" />

        <ImageButton android:id="@+id/btnAspectRatio"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_aspect_ratio"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Aspect ratio" />

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Motion AF toggle button -->
        <ImageButton android:id="@+id/btnMotionAf"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_motion_af_on"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#00E5FF"
            android:contentDescription="Motion AF" />

        <ImageButton android:id="@+id/btnGrid"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_grid_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Grid" />

        <ImageButton android:id="@+id/btnLevel"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_level"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Level" />

        <ImageButton android:id="@+id/btnLocation"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_location_off"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Location" />

        <ImageButton android:id="@+id/btnSettings"
            android:layout_width="44dp" android:layout_height="44dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp" android:tint="#FFFFFF"
            android:contentDescription="Settings" />
    </LinearLayout>

    <!-- Exposure / WB panel (long-press to show) -->
    <LinearLayout
        android:id="@+id/exposurePanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#AA000000"
        android:padding="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/modeScrollView">

        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="40dp"
            android:scrollbars="none">
            <LinearLayout android:id="@+id/wbContainer"
                android:layout_width="wrap_content" android:layout_height="match_parent"
                android:orientation="horizontal" android:gravity="center_vertical"/>
        </HorizontalScrollView>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                android:text="ISO" android:textColor="#FFFFFF" android:textSize="12sp"/>
            <SeekBar android:id="@+id/isoSlider"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:max="100" android:progress="0"/>
            <TextView android:id="@+id/isoValue"
                android:layout_width="50dp" android:layout_height="wrap_content"
                android:text="AUTO" android:textColor="#FFFFFF" android:textSize="12sp"
                android:gravity="end"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                android:text="EV" android:textColor="#FFFFFF" android:textSize="12sp"/>
            <SeekBar android:id="@+id/exposureSlider"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:max="100" android:progress="50"/>
            <TextView android:id="@+id/exposureValue"
                android:layout_width="50dp" android:layout_height="wrap_content"
                android:text="0.0" android:textColor="#FFFFFF" android:textSize="12sp"
                android:gravity="end"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Mode bar -->
    <HorizontalScrollView
        android:id="@+id/modeScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#CC000000"
        app:layout_constraintBottom_toTopOf="@id/zoomBar">
        <LinearLayout
            android:id="@+id/modeBar"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"/>
    </HorizontalScrollView>

    <!-- Zoom bar -->
    <SeekBar
        android:id="@+id/zoomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="100" android:progress="0"
        android:paddingStart="32dp" android:paddingEnd="32dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottomControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="24dp" android:paddingEnd="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/galleryThumb"
            android:layout_width="64dp" android:layout_height="64dp"
            android:scaleType="centerCrop" android:background="#333333"
            android:contentDescription="Gallery"/>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <FrameLayout android:layout_width="80dp" android:layout_height="80dp">
            <ImageButton
                android:id="@+id/shutterButton"
                android:layout_width="80dp" android:layout_height="80dp"
                android:src="@drawable/ic_shutter" android:background="@null"
                android:contentDescription="Shutter"/>
            <TextView
                android:id="@+id/timerCountdown"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:gravity="center" android:textColor="#FFFFFF"
                android:textSize="32sp" android:textStyle="bold"
                android:visibility="gone"/>
        </FrameLayout>

        <Space android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnFlipCamera"
            android:layout_width="64dp" android:layout_height="64dp"
            android:src="@drawable/ic_flip_camera"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="#FFFFFF"
            android:contentDescription="Switch camera"/>
    </LinearLayout>

    <!-- Timer fullscreen overlay -->
    <TextView
        android:id="@+id/timerFullscreen"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:gravity="center" android:textColor="#FFFFFF"
        android:textSize="96sp" android:textStyle="bold"
        android:background="#88000000" android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Mode badge -->
    <TextView
        android:id="@+id/modeBadge"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textColor="#FFFFFF" android:textSize="11sp"
        android:background="#CC007AFF"
        android:paddingStart="8dp" android:paddingEnd="8dp"
        android:paddingTop="3dp" android:paddingBottom="3dp"
        android:visibility="gone" android:layout_margin="8dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
