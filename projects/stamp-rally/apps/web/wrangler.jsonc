{
  // stamp-rally-web — Cloudflare Pages
  "name": "stamp-rally-web",
  "compatibility_date": "2024-11-01",
  "compatibility_flags": ["nodejs_compat"],
  "pages_build_output_dir": ".vercel/output/static",

  "vars": {
    // デプロイ後の Workers URL に変更してください
    "NEXT_PUBLIC_API_URL": "https://stamp-rally-api.your-subdomain.workers.dev"
  }
}
